{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/limengkai/.codex/hook-probe.sh\" SessionStart",
            "statusMessage": "Hook probe SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/limengkai/.codex/hook-probe.sh\" UserPromptSubmit",
            "statusMessage": "Hook probe UserPromptSubmit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/limengkai/.codex/hook-probe.sh\" PostToolUse",
            "statusMessage": "Hook probe PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/limengkai/.codex/hook-probe.sh\" Stop",
            "statusMessage": "Hook probe Stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/limengkai/.codex/hook-probe.sh\" PreCompact",
            "statusMessage": "Hook probe PreCompact"
          }
        ]
      }
    ]
  }
}
