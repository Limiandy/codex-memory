#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import shutil
import sqlite3
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


PLUGIN_ROOT = Path(__file__).resolve().parents[1]
HOOK = PLUGIN_ROOT / "hooks" / "codex-memory-hook.sh"
STATE_DIR = Path(os.environ.get("CODEX_MEMORY_STATE_DIR", "~/.codex-memory")).expanduser()
REPORT_PATH = Path("/private/tmp/codex-memory-full-simulation-report.json")


MESSAGES = [
    ("noise", "这是一条普通测试消息。"),
    ("preference", "请记住，我默认希望你用中文回答，并且尽量简洁。"),
    ("project", "项目架构决策：MCP 和 hook 必须是两条不重叠的路，不能互相调用。"),
    ("secret", "临时测试：api_key = sk-testShouldNeverBeStored1234567890"),
    ("task", "当前任务：继续测试 hooks 记忆系统，让它真的帮助 Codex。"),
    ("experience", "经验：如果 hook 内部调用 codex exec，必须设置 internal 标记，否则会递归触发。"),
    ("duplicate", "项目架构决策：MCP 和 hook 必须是两条不重叠的路，不能互相调用。"),
    ("conflict", "项目架构变更：MCP 和 hook 应该互相调用，形成一条统一链路。"),
    ("fact", "事实：codex-memory 使用 GPT-5.4-Mini 作为 memory-engine 和 memory-review 模型。"),
    ("temporary", "这次只需要临时打开 debug 日志，之后可以关闭。"),
]


def main() -> int:
    parser = argparse.ArgumentParser(description="Run full Codex Memory hook simulation.")
    parser.add_argument("--rounds", type=int, default=100)
    parser.add_argument("--clear-before", action="store_true")
    parser.add_argument("--clear-after", action="store_true")
    parser.add_argument("--wait-timeout", type=int, default=150)
    args = parser.parse_args()

    if args.clear_before:
        clear_data()

    STATE_DIR.mkdir(parents=True, exist_ok=True)
    start = time.time()
    results = []
    for index in range(args.rounds):
        kind, text = MESSAGES[index % len(MESSAGES)]
        prompt = f"[sim-{index + 1:03d}/{kind}] {text}"
        before_events = event_ids()
        hook_result = call_hook(index, prompt)
        event_id = newest_event_id(before_events)
        processed = wait_event_processed(event_id, args.wait_timeout) if event_id else False
        results.append(
            {
                "round": index + 1,
                "kind": kind,
                "prompt": prompt,
                "hook_result": hook_result,
                "event_id": event_id,
                "processed": processed,
                "stats": stats(),
            }
        )
        print(f"{index + 1:03d}/{args.rounds} {kind} event={event_id} processed={processed}", flush=True)

    report = {
        "started_at": iso_now(),
        "duration_seconds": round(time.time() - start, 2),
        "rounds": args.rounds,
        "state_dir": str(STATE_DIR),
        "final_stats": stats(),
        "memory_status_counts": memory_status_counts(),
        "injection_hits": sum(1 for item in results if item["hook_result"].get("hookSpecificOutput")),
        "failed_rounds": [item for item in results if not item["processed"]],
        "samples": recent_memories(20),
        "round_results": results,
    }
    REPORT_PATH.write_text(json.dumps(report, ensure_ascii=False, indent=2), encoding="utf-8")
    print(f"REPORT {REPORT_PATH}")
    print(json.dumps({k: report[k] for k in ("duration_seconds", "rounds", "final_stats", "memory_status_counts", "injection_hits")}, ensure_ascii=False, indent=2))

    if args.clear_after:
        clear_data()
        print("CLEARED codex-memory data")
    return 0


def call_hook(index: int, prompt: str) -> dict:
    env = os.environ.copy()
    env.pop("CODEX_MEMORY_FAKE_MODEL", None)
    env["PLUGIN_ROOT"] = str(PLUGIN_ROOT)
    env["CODEX_MEMORY_LOG_LEVEL"] = "DEBUG"
    payload = {
        "session_id": "simulation-session",
        "turn_id": f"simulation-turn-{index + 1:03d}",
        "transcript_path": str(STATE_DIR / "simulation-transcript.jsonl"),
        "cwd": str(Path.cwd()),
        "hook_event_name": "UserPromptSubmit",
        "model": "gpt-5.5",
        "permission_mode": "bypassPermissions",
        "prompt": prompt,
    }
    proc = subprocess.run(
        [str(HOOK), "user_message"],
        input=json.dumps(payload, ensure_ascii=False),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env,
        timeout=20,
    )
    if proc.returncode != 0:
        return {"error": proc.stderr.strip() or proc.stdout.strip(), "returncode": proc.returncode}
    try:
        return json.loads(proc.stdout or "{}")
    except json.JSONDecodeError:
        return {"raw": proc.stdout}


def clear_data() -> None:
    for path in (STATE_DIR,):
        if path.exists():
            shutil.rmtree(path)


def db_path() -> Path:
    return STATE_DIR / "ledger.sqlite3"


def connect():
    return sqlite3.connect(str(db_path()), timeout=60)


def event_ids() -> set[str]:
    if not db_path().exists():
        return set()
    with connect() as conn:
        try:
            return {row[0] for row in conn.execute("SELECT id FROM events")}
        except sqlite3.OperationalError:
            return set()


def newest_event_id(before: set[str]) -> str | None:
    if not db_path().exists():
        return None
    with connect() as conn:
        rows = conn.execute("SELECT id FROM events WHERE event_type='user_message' ORDER BY created_at DESC LIMIT 10").fetchall()
    for (event_id,) in rows:
        if event_id not in before:
            return event_id
    return rows[0][0] if rows else None


def wait_event_processed(event_id: str, timeout: int) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        with connect() as conn:
            row = conn.execute("SELECT processed_at, process_error FROM events WHERE id=?", (event_id,)).fetchone()
        if row and row[0]:
            return True
        if row and row[1]:
            return False
        time.sleep(1)
    return False


def stats() -> dict:
    if not db_path().exists():
        return {"pending": 0, "failed": 0}
    with connect() as conn:
        pending = conn.execute("SELECT COUNT(*) FROM events WHERE processed_at IS NULL AND process_error IS NULL").fetchone()[0]
        failed = conn.execute("SELECT COUNT(*) FROM events WHERE processed_at IS NULL AND process_error IS NOT NULL").fetchone()[0]
    return {"pending": pending, "failed": failed}


def memory_status_counts() -> dict:
    if not db_path().exists():
        return {}
    with connect() as conn:
        return {status: count for status, count in conn.execute("SELECT status, COUNT(*) FROM memories GROUP BY status")}


def recent_memories(limit: int) -> list[dict]:
    if not db_path().exists():
        return []
    with connect() as conn:
        conn.row_factory = sqlite3.Row
        rows = conn.execute("SELECT id,status,memory_type,scope,ttl,content,review_json,created_at FROM memories ORDER BY created_at DESC LIMIT ?", (limit,)).fetchall()
    return [dict(row) for row in rows]


def iso_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


if __name__ == "__main__":
    raise SystemExit(main())
