    codex = "/tmp/projects/codex-memory"
    vue = "/tmp/projects/vue-admin"
    react = "/tmp/projects/react-portal"
    jquery = "/tmp/projects/jquery-legacy"
    life = "/tmp/life/home"
    water = "/tmp/projects/water-engineering"
    return [
        Scenario("noise", "这是一条普通测试消息。", None, "neutral", codex),
        Scenario("secret", "临时测试 api_key = sk-testShouldNeverBeStored1234567890", _candidate("api_key = sk-testShouldNeverBeStored1234567890", "fact", "session", "general", "fact", "secret", ["api_key"], 0.96, 0.9, "session"), "neutral", codex),
        Scenario("temporary_debug", "这次只需要临时打开 debug 日志。", _candidate("这次只需要临时打开 debug 日志，之后关闭。", "temporary", "session", "memory_system", "workflow", "logging", ["debug", "日志"], 0.9, 0.5, "session"), "neutral", codex),
        Scenario("preference_language", "请记住，默认用中文回答，并且尽量简洁。", _candidate("用户默认希望用中文回答，并且尽量简洁。", "user_preference", "global", "user_profile", "preference", "language", ["中文", "简洁"]), "use_recalled", codex),
        Scenario("preference_no_emoji", "记住，不要主动使用 emoji。", _candidate("用户偏好：不要主动使用 emoji。", "user_preference", "global", "user_profile", "preference", "style", ["emoji", "不要"]), "use_recalled", codex),
        Scenario("project_boundary", "项目架构决策：MCP 与 hook 必须是两条不重叠路径。", _candidate("项目架构决策：MCP 和 hook 必须是两条不重叠的路径，不能互相调用。", "project_context", "project", "memory_system", "architecture", "mcp_hook", ["MCP", "hook", "不重叠"]), "use_recalled", codex),
        Scenario("project_boundary_duplicate", "MCP 和 hook 还是要保持分离。", _candidate("项目架构上，MCP 与 hook 需要保持两条不重叠路径，不能互相调用。", "project_context", "project", "memory_system", "architecture", "mcp_hook", ["MCP", "hook", "不重叠"]), "use_recalled", codex),
        Scenario("project_boundary_conflict", "项目架构变更：MCP 和 hook 应该互相调用。", _candidate("项目架构变更：MCP 和 hook 应该互相调用，形成统一链路。", "project_context", "project", "memory_system", "architecture", "mcp_hook", ["MCP", "hook", "互相调用"]), "neutral", codex),
        Scenario("hook_recursion", "经验：hook 内调用 codex exec 必须设置 internal 标记。", _candidate("经验：如果 hook 内部调用 codex exec，必须设置 internal 标记，否则会递归触发。", "experience", "project", "software_engineering", "lesson", "hook", ["hook", "codex exec", "internal"]), "use_recalled", codex),
        Scenario("bad_overbroad_testing", "经验：所有测试建议都要长期注入每次回答。", _candidate("经验：所有项目都必须长期注入这条宽泛测试建议。", "experience", "global", "software_engineering", "lesson", "testing", ["测试", "注入", "质量"]), "ignore_recalled", codex),
        Scenario("vue_frontend", "Vue 管理平台经验：表单权限和接口封装要分层。", _candidate("Vue 管理平台经验：表单权限、路由守卫和接口封装要分层，避免页面组件直接散落业务请求。", "experience", "project", "software_engineering", "lesson", "frontend", ["Vue", "管理平台", "接口封装"]), "use_recalled", vue),
        Scenario("react_frontend", "React 门户经验：状态边界和缓存策略要明确。", _candidate("React 门户经验：状态边界、接口缓存和首屏加载预算要明确，避免全局状态承载临时页面细节。", "experience", "project", "software_engineering", "lesson", "frontend", ["React", "门户", "状态边界"]), "use_recalled", react),
