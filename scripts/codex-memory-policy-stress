def _assistant_message(scenario: Scenario, context: str) -> str:
    if scenario.assistant_mode == "use_recalled" and context:
        return f"我会采用相关记忆继续处理：{context[:500]}"
    if scenario.assistant_mode == "ignore_recalled":
        return "这次直接给出当前问题的答案，不采用历史提示。"
    return "收到。"


def _metrics(service: MemoryService) -> dict[str, Any]:
    memories = service.list_memories(limit=200)
    policies = service.ledger.list_governance_policies(active=True)
    recalls = service.ledger.list_recall_events(limit=5000)
    status = Counter(memory["status"] for memory in memories)
    false_active = [_false_active_reason(memory) for memory in memories if memory.get("status") == "active" and _false_active_reason(memory)]
    return {
        "status": dict(sorted(status.items())),
        "active_count": status.get("active", 0),
        "false_active_count": len(false_active),
        "false_active": false_active[:10],
        "policy_count": len(policies),
        "policy_hits": sum(int(policy.get("hit_count") or 0) for policy in policies),
        "policies": [
            {
                "id": policy["id"],
                "type": policy["policy_type"],
                "action": policy["action"],
                "source_memory_id": policy.get("source_memory_id"),
                "hit_count": policy.get("hit_count"),
                "matcher": policy.get("matcher_json"),
            }
            for policy in policies
        ],
        "recall_event_count": len(recalls),
        "total_injected": sum(len(event.get("memory_ids_json") or []) for event in recalls),
    }


def _compact_metrics(service: MemoryService) -> dict[str, Any]:
    metrics = _metrics(service)
    return {
        "active_count": metrics["active_count"],
        "false_active_count": metrics["false_active_count"],
        "policy_count": metrics["policy_count"],
        "policy_hits": metrics["policy_hits"],
    }


def _policy_effects(service: MemoryService) -> list[dict[str, Any]]:
    recalls = service.ledger.list_recall_events(limit=5000)
    policies = service.ledger.list_governance_policies(active=True)
    effects = []
    for policy in policies:
        source_id = str(policy.get("source_memory_id") or "")
        before = 0
        after = 0
        created_at = str(policy.get("created_at") or "")
        for event in recalls:
            ids = [str(item) for item in event.get("memory_ids_json") or []]
            if not source_id or source_id not in ids:
                continue
            if str(event.get("created_at") or "") <= created_at:
                before += 1
            else:
                after += 1
        effects.append(
            {
                "policy_id": policy["id"],
                "policy_type": policy["policy_type"],
                "action": policy["action"],
                "source_memory_id": source_id,
                "hit_count": policy.get("hit_count"),
                "source_recalled_before_policy": before,
                "source_recalled_after_policy": after,
            }
        )
    return effects


def _false_active_reason(memory: dict[str, Any]) -> dict[str, Any] | None:
    content = str(memory.get("content") or "").lower()
    reasons = []
    if "sk-" in content or "api_key" in content:
        reasons.append("secret")
    if memory.get("memory_type") in {"temporary", "task_state"}:
        reasons.append("temporary_or_task_state")
    if "这是一条普通测试消息" in content:
        reasons.append("noise")
    if reasons:
        return {"id": memory.get("id"), "content": memory.get("content"), "reasons": reasons}
    return None


def _passed(service: MemoryService, governance: dict[str, Any]) -> bool:
    metrics = _metrics(service)
    effects = _policy_effects(service)
    return (
        metrics["false_active_count"] == 0
        and metrics["policy_count"] >= 1
        and metrics["policy_hits"] >= 1
        and any(effect["source_recalled_before_policy"] > 0 and effect["source_recalled_after_policy"] == 0 for effect in effects)
        and governance.get("report", {}).get("injection_pressure") in {"low", "medium"}
    )


def _summary(report: dict[str, Any]) -> dict[str, Any]:
    return {
        "passed": report["passed"],
        "duration_seconds": report["duration_seconds"],
        "rounds": report["rounds"],
        "final_metrics": {
            key: report["final_metrics"][key]
            for key in ("status", "active_count", "false_active_count", "policy_count", "policy_hits", "recall_event_count", "total_injected")
        },
        "final_governance_issue_count": report["final_governance"].get("report", {}).get("issue_count"),
        "policy_effects": report["policy_effects"],
    }


if __name__ == "__main__":
    raise SystemExit(main())
