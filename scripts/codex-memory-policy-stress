#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import tempfile
import time
from collections import Counter
from dataclasses import dataclass
from pathlib import Path
from typing import Any

from codex_memory.config import Config
from codex_memory.ledger import project_key_for_cwd
from codex_memory.schema import Evidence, MemoryCandidate
from codex_memory.service import MemoryService


REPORT_PATH = Path("/private/tmp/codex-memory-policy-stress-report.json")


@dataclass(frozen=True)
class Scenario:
    name: str
    prompt: str
    candidate: MemoryCandidate | None
    assistant_mode: str
    cwd: str


def main() -> int:
    parser = argparse.ArgumentParser(description="Run broad closed-loop Codex Memory governance policy stress test.")
    parser.add_argument("--rounds", type=int, default=200)
    parser.add_argument("--govern-every", type=int, default=25)
    parser.add_argument("--state-dir", default="")
    args = parser.parse_args()

    os.environ["CODEX_MEMORY_FAKE_MODEL"] = "1"
    os.environ["CODEX_MEMORY_DISABLE_MEMPALACE"] = "1"

    state_dir = Path(args.state_dir) if args.state_dir else Path(tempfile.mkdtemp(prefix="codex-memory-policy-stress-", dir="/private/tmp"))
    service = _service(state_dir)
    start = time.time()
    rounds = []
    snapshots = []
    try:
        scenarios = _scenarios()
        for index in range(args.rounds):
            scenario = scenarios[index % len(scenarios)]
            turn_id = f"stress-turn-{index + 1:04d}"
            context = service.prompt_context(
                scenario.prompt,
                limit=6,
                cwd=scenario.cwd,
                session_id="policy-stress",
                turn_id=turn_id,
            )
            outcome = service.apply_recall_outcome(
                "policy-stress",
                turn_id,
                _assistant_message(scenario, context),
            )
            admission = _admit_candidate(service, scenario.candidate, cwd=scenario.cwd, session_id="policy-stress")
            if (index + 1) % args.govern_every == 0:
                before = _metrics(service)
                governed = service.govern_memories(apply=True)
                after = _metrics(service)
                snapshots.append({"round": index + 1, "before": before, "governed": governed, "after": after})
            rounds.append(
                {
                    "round": index + 1,
                    "scenario": scenario.name,
                    "context_injected": bool(context),
                    "outcome": outcome,
                    "admission": admission,
                    "metrics": _compact_metrics(service),
                }
            )
            print(f"{index + 1:03d}/{args.rounds} {scenario.name} injected={bool(context)} admission={admission.get('status')}", flush=True)

        final_governance = service.govern_memories(apply=False)
        report = {
            "passed": _passed(service, final_governance),
            "duration_seconds": round(time.time() - start, 2),
            "rounds": args.rounds,
            "govern_every": args.govern_every,
            "state_dir": str(state_dir),
            "final_metrics": _metrics(service),
            "final_governance": final_governance,
            "snapshots": snapshots,
            "policy_effects": _policy_effects(service),
            "active_memories": service.list_memories(status="active", limit=200),
            "round_samples": rounds[:5] + rounds[-5:],
        }
        REPORT_PATH.write_text(json.dumps(report, ensure_ascii=False, indent=2), encoding="utf-8")
        print(f"REPORT {REPORT_PATH}")
        print(json.dumps(_summary(report), ensure_ascii=False, indent=2))
        return 0 if report["passed"] else 1
    finally:
        service.close()


def _service(state_dir: Path) -> MemoryService:
    config = Config(
        model="gpt-5.4-mini",
        state_dir=state_dir,
        ledger_path=state_dir / "ledger.sqlite3",
        palace_path=None,
        min_active_confidence=0.82,
        min_quarantine_confidence=0.62,
        duplicate_threshold=0.9,
        max_evidence_quote_chars=500,
    )
    return MemoryService(config)


def _admit_candidate(service: MemoryService, candidate: MemoryCandidate | None, cwd: str, session_id: str) -> dict[str, Any]:
    if candidate is None:
        return {"status": "none"}
    project_key = project_key_for_cwd(cwd)
    local_duplicates = service.ledger.find_active_duplicates(
        candidate.content,
        candidate.memory_type,
        candidate.scope,
        project_key=project_key,
        session_id=session_id,
    )
    if local_duplicates:
        review = {
            "status": "superseded",
            "reasons": ["merged_exact_duplicate"],
            "duplicates": [{"id": item["id"], "content": item["content"]} for item in local_duplicates[:3]],
        }
        memory_id = service.ledger.add_candidate(candidate, "superseded", review, project_key=project_key, session_id=session_id)
        service.ledger.add_review_feedback(str(local_duplicates[0]["id"]), "merge_duplicate", f"merged {memory_id}")
        return {"id": memory_id, "status": "superseded", "reason": "duplicate"}

    conflicts = service.ledger.find_active_conflicts(
        candidate.content,
        candidate.memory_type,
        candidate.scope,
        project_key=project_key,
        session_id=session_id,
    )
    review = service.reviewer.review(candidate, [])
    policy_decision = service.ledger.candidate_policy_decision(candidate)
    if policy_decision:
        review = {
            **review,
            "status": {"quarantine": "quarantined", "reject": "rejected", "supersede": "superseded"}.get(
                str(policy_decision["action"]), "rejected"
            ),
            "reasons": [*review.get("reasons", []), "governance_policy_matched"],
            "governance_policy": policy_decision,
        }
    if conflicts and review["status"] == "active":
        review = {
            **review,
            "status": "quarantined",
            "reasons": [*review.get("reasons", []), "possible_conflict_with_active_memory"],
            "conflicts": [{"id": item["id"], "content": item["content"]} for item in conflicts[:3]],
        }
    memory_id = service.ledger.add_candidate(candidate, str(review["status"]), review, project_key=project_key, session_id=session_id)
    if review["status"] == "active":
        service.ledger.link_related_active_memories(memory_id)
        service.consolidate_memories()
    return {"id": memory_id, "status": review["status"], "reasons": review.get("reasons", [])}


def _candidate(
    content: str,
    memory_type: str,
    scope: str,
    domain: str,
    category: str,
    subcategory: str,
    triggers: list[str],
    confidence: float = 0.95,
    importance: float = 0.85,
    ttl: str = "long",
    evidence_source: str = "user_message",
) -> MemoryCandidate:
    return MemoryCandidate(
        content=content,
        memory_type=memory_type,
        proposed_action="store",
        confidence=confidence,
        importance=importance,
        ttl=ttl,
        scope=scope,
        domain=domain,
        category=category,
        subcategory=subcategory,
        abstraction_level="principle" if any(term in content for term in ("必须", "不要", "原则", "默认")) else "pattern",
        triggers=triggers,
        evidence=[Evidence(source=evidence_source, quote=content)],
        reason="policy stress scenario",
    )


