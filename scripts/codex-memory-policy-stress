        Scenario("fact_model", "事实：codex-memory 使用 GPT-5.4-Mini 做 memory-engine。", _candidate("codex-memory 使用 GPT-5.4-Mini 作为 memory-engine 和 memory-review 模型。", "fact", "project", "memory_system", "fact", "model", ["GPT-5.4-Mini", "memory-engine"], 0.96, 0.8), "use_recalled", codex),
        Scenario("logging_pretty", "经验：JSONL 日志要提供 pretty 视图。", _candidate("经验：面向人类排查的 JSONL 日志必须提供 pretty 视图，否则实时观察链路很困难。", "experience", "project", "memory_system", "lesson", "logging", ["日志", "JSONL", "pretty"]), "use_recalled", codex),
        Scenario("bad_generic_process", "经验：所有项目都应该把流程提示每次注入。", _candidate("经验：所有项目都应该每次注入完整流程提醒。", "experience", "global", "general", "workflow", "general", ["流程", "注入"]), "ignore_recalled", codex),
