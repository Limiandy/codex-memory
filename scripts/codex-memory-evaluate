            "evidence": [Evidence(source="user_message", quote="当前正在跑 50 轮测试。")],
        },
    ),
    (
        "experience",
        "active",
        {
            "content": "经验：如果 hook 内部调用 codex exec，必须设置 internal 标记，否则会递归触发。",
            "memory_type": "experience",
            "confidence": 0.95,
            "importance": 0.86,
            "ttl": "long",
            "scope": "project",
            "evidence": [Evidence(source="user_message", quote="如果 hook 内部调用 codex exec，必须设置 internal 标记，否则会递归触发。")],
        },
    ),
]


def main() -> int:
    os.environ["CODEX_MEMORY_FAKE_MODEL"] = "1"
    with tempfile.TemporaryDirectory() as tmp:
        config = Config(
            model="gpt-5.4-mini",
            state_dir=Path(tmp),
            ledger_path=Path(tmp) / "ledger.sqlite3",
            palace_path=None,
            min_active_confidence=0.82,
            min_quarantine_confidence=0.62,
            duplicate_threshold=0.9,
            max_evidence_quote_chars=500,
        )
        reviewer = MemoryReviewer(config, CodexMiniClient(config))
        rows = []
        for name, expected, data in CASES:
            candidate = MemoryCandidate(proposed_action="store", reason="evaluation case", **data)
            review = reviewer.review(candidate)
            rows.append({"name": name, "expected": expected, "actual": review["status"], "passed": review["status"] == expected, "reasons": review.get("reasons", [])})
    active_predictions = [row for row in rows if row["actual"] == "active"]
    false_active = [row for row in active_predictions if row["expected"] != "active"]
    report = {
        "total": len(rows),
        "passed": sum(1 for row in rows if row["passed"]),
        "failed": [row for row in rows if not row["passed"]],
        "active_precision": 1.0 if not active_predictions else round(1 - len(false_active) / len(active_predictions), 4),
        "false_active": false_active,
        "rows": rows,
    }
    print(json.dumps(report, ensure_ascii=False, indent=2))
    return 0 if not report["failed"] and not false_active else 1


if __name__ == "__main__":
    raise SystemExit(main())
